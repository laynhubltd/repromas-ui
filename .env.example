# ─────────────────────────────────────────────
# Environment configuration
# Copy to .env.development / .env.staging / .env.production as needed
# ─────────────────────────────────────────────

# API base URL
# development  → http://localhost:8000/api
# staging      → https://api.repromas.com/api
# production   → https://api.repromas.com/api
VITE_API_BASE_URL=http://localhost:8000/api

# Set to true to bypass the real API and use mock auth (dev only)
VITE_USE_MOCK_AUTH=false
